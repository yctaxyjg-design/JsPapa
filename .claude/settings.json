{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(jq:*)",
      "Bash(python3:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(date:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:-f *)",
      "Bash(chmod:*)",
      "Bash(mktemp:*)",
      "Bash(bash scripts/economist/*)",
      "Bash(./scripts/economist/*)",
      "Bash(scripts/economist/*)",
      "Bash(bash scripts/ft-edit/*)",
      "Bash(./scripts/ft-edit/*)",
      "Bash(scripts/ft-edit/*)",
      "Bash(python3 scripts/ft-edit/*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git rev-parse:*)",
      "WebFetch(domain:economist.com)",
      "WebFetch(domain:www.economist.com)",
      "WebFetch(domain:ft.com)",
      "WebFetch(domain:www.ft.com)"
    ],
    "deny": [
      "WebFetch(domain:click.e.economist.com)",
      "Bash(curl:*click.e.economist.com*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/ft-edit/bootstrap.sh"
          }
        ]
      }
    ]
  }
}
