### AL ###
#Template for AL projects for Dynamics 365 Business Central
#launch.json folder
.vscode/
#Cache folder
.alcache/
#Symbols folder
.alpackages/
#Snapshots folder
.snapshots/
#Testing Output folder
.output/
#Extension App-file
*.app
#Rapid Application Development File
rad.json
#Translation Base-file
*.g.xlf
#License-file
*.flf
#Test results file
TestResults.xml

### Economist scheduler ###
# Generated weekly analyses (personal copyright-restricted output, never commit)
economist/out/
# Local Claude Code settings overrides (machine-specific)
.claude/settings.local.json

### KIFRS search ###
# Full-text standards (copyright KASB) and the enriched corpus must not be committed
kifrs/raw/
kifrs/corpus.full.json
# Local RAG index / embedding cache (machine-local, regenerable)
kifrs/build/.kifrs_index.json
kifrs/build/.kifrs_embed_cache.json
# Python bytecode
__pycache__/
*.pyc

# Build artifacts (binary, regenerable)
kifrs/*.zip
