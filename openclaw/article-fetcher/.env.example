# translate.sh 가 번역에 쓸 LLM 엔드포인트 설정.
# 이 파일을 .env 로 복사해 값을 채우세요.  (.env 는 커밋 금지 — .gitignore 참고)

# --- 옵션 A: 로컬 LM Studio (기본, 키 불필요) ---
# LLM_URL=http://127.0.0.1:1234/v1/chat/completions
# LLM_MODEL=qwen3.6-35b-a3b

# --- 옵션 B: GLM 5.2 클라우드 (Z.ai / BigModel) ---
# LLM_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
# LLM_MODEL=glm-5.2
# LLM_API_KEY=여기에_API_키
